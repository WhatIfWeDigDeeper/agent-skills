[project]
name = "simple-project"
version = "0.1.0"
requires-python = ">=3.9"
description = "Eval fixture for uv-deps skill testing"
dependencies = [
  "requests>=2.28.0",
  "tomli>=2.0.1",
]

[dependency-groups]
dev = [
  "pytest>=7.4.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
