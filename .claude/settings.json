{
  "model": "opusplan",
  "remote": {
    "enabled": true
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Search",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(.env*)",
      "Write(.env*)",
      "Edit(.env*)",
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'gh pr merge' && echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PostToolUse\", \"additionalContext\": \"If the PR was merged successfully, ask the user: Want to run /learn to capture any lessons from this session?\"}}' || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'agent-skills' -message 'Claude needs your permission' -sound Glass -activate com.microsoft.VSCode"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'agent-skills' -message 'Claude has a question for you' -sound Glass -activate com.microsoft.VSCode"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "enableWeakerNetworkIsolation": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true,
      "allowedHosts": [
        "api.github.com",
        "api.githubcopilot.com",
        "api.individual.githubcopilot.com",
        "cloudcode-pa.googleapis.com",
        "geminicli.com",
        "github.com",
        "oauth2.googleapis.com",
        "registry.npmjs.org",
        "telemetry.individual.githubcopilot.com"
      ]
    },
    "excludedCommands": [
      "docker",
      "gh",
      "git",
      "psql",
      "mysql",
      "mongosh",
      "npm",
      "npx",
      "playwright",
      "redis-cli",
      "uv"
    ]
  }
}
